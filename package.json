{
  "name": "@notesaner/source",
  "version": "0.0.0",
  "private": true,
  "description": "Web-first Obsidian alternative with real-time collaboration",
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "nx run-many -t serve -p web server",
    "dev:web": "nx serve web",
    "dev:server": "nx serve server",
    "build": "nx run-many -t build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "nx run-many -t lint",
    "type-check": "nx run-many -t type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "nx run server:prisma-generate",
    "db:migrate": "nx run server:prisma-migrate",
    "db:push": "nx run server:prisma-push",
    "db:studio": "nx run server:prisma-studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.12.4",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "msgpackr-extract"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nx/eslint": "^22.6.1",
    "@nx/eslint-plugin": "^22.6.1",
    "@nx/js": "^22.6.1",
    "@nx/next": "^22.6.1",
    "@nx/workspace": "^22.6.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nx": "^22.6.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.1"
  }
}

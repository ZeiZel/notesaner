{
  "name": "plugin-ai",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/plugin-ai/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:plugin"],
  "targets": {
    "type-check": {
      "command": "tsc --noEmit -p packages/plugin-ai/tsconfig.json"
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest run",
        "cwd": "packages/plugin-ai"
      }
    },
    "test:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm vitest",
        "cwd": "packages/plugin-ai"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["eslint {projectRoot}/src --ext .ts,.tsx"]
      }
    }
  }
}

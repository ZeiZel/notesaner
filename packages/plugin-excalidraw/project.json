{
  "name": "plugin-excalidraw",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/plugin-excalidraw/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:plugin"],
  "targets": {
    "type-check": {
      "command": "tsc --noEmit -p packages/plugin-excalidraw/tsconfig.json"
    },
    "test": {
      "executor": "@nx/vite:test",
      "options": {
        "configFile": "packages/plugin-excalidraw/vitest.config.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["eslint {projectRoot}/src --ext .ts,.tsx"]
      }
    }
  }
}

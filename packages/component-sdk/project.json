{
  "name": "component-sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/component-sdk/src",
  "projectType": "library",
  "targets": {
    "type-check": {
      "command": "tsc --noEmit -p packages/component-sdk/tsconfig.json"
    },
    "test": {
      "command": "vitest run --config packages/component-sdk/vitest.config.ts"
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["eslint {projectRoot}/src --ext .ts,.tsx"]
      }
    }
  },
  "tags": ["scope:shared", "type:component"]
}

# =============================================================================
# Notesaner — Development Environment Variables
# =============================================================================
# Used by: docker compose --profile dev
# These values are safe defaults for local development.
# =============================================================================

# PostgreSQL
POSTGRES_USER=notesaner
POSTGRES_PASSWORD=notesaner
POSTGRES_DB=notesaner

# Redis
REDIS_PASSWORD=redis

# JWT (not secure — dev only)
JWT_SECRET=dev-jwt-secret-change-in-prod-not-for-production
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=2592000

# Application URLs
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Feature flags
ALLOW_REGISTRATION=true
REQUIRE_EMAIL_VERIFICATION=false

# Logging
LOG_LEVEL=debug

# =============================================================================
# Notesaner — Production Environment Variables
# =============================================================================
#
# Copy this file to docker/.env and fill in all values before running:
#   cp docker/.env.example docker/.env
#   chmod 600 docker/.env       # restrict read access — contains secrets
#
# NEVER commit docker/.env to version control.
# Add `docker/.env` to .gitignore (already done in this repo).
#
# Generation helpers:
#   openssl rand -base64 64     # JWT secret, ValKey password
#   openssl rand -hex 32        # config tokens
#
# Required fields are marked with (REQUIRED).
# Fields with a default value in docker-compose.prod.yml are marked (optional).
# =============================================================================


# =============================================================================
# Registry & Image coordinates
# Used by docker-compose.prod.yml when pulling pre-built images from a registry
# =============================================================================

# Container registry hostname (default: ghcr.io)
REGISTRY=ghcr.io

# Registry org / user owning the images
IMAGE_ORG=notesaner

# Docker image tag to deploy (e.g. sha-abc1234, v1.2.3, latest)
# Best practice: pin to a specific digest or semantic version in production
IMAGE_TAG=latest


# =============================================================================
# Networking
# =============================================================================

# Public domain serving the application
# Used for CORS policy, HSTS preload, and email links
DOMAIN=notesaner.example.com                          # (REQUIRED)

# Ports exposed by the Nginx container on the host
HTTP_PORT=80
HTTPS_PORT=443


# =============================================================================
# PostgreSQL 17
# =============================================================================

POSTGRES_USER=notesaner                               # (REQUIRED)
POSTGRES_PASSWORD=change-me-use-openssl-rand-base64-32 # (REQUIRED) — at least 32 chars
POSTGRES_DB=notesaner                                 # (REQUIRED)

# Full DSN assembled by docker-compose.prod.yml from the above vars.
# Override only if using an external managed database (RDS, Cloud SQL, etc.)
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public


# =============================================================================
# ValKey 8 (Redis-compatible)
# =============================================================================

# Password for all ValKey connections (session cache + BullMQ queues)
VALKEY_PASSWORD=change-me-use-openssl-rand-base64-32  # (REQUIRED) — at least 32 chars

# Maximum memory before LRU eviction kicks in
VALKEY_MAX_MEMORY=256mb

# Random token used to rename dangerous admin commands (FLUSHALL, CONFIG, DEBUG)
# This prevents accidental or malicious data loss in production
VALKEY_CONFIG_TOKEN=change-me-use-openssl-rand-hex-16 # (REQUIRED) — must be hex, 16 chars


# =============================================================================
# JWT Authentication
# =============================================================================

# HMAC signing secret — must be cryptographically random and at least 64 chars
# Generate: openssl rand -base64 64
JWT_SECRET=change-me-use-openssl-rand-base64-64       # (REQUIRED)

# Access token TTL in seconds (default: 900 = 15 minutes)
JWT_ACCESS_TOKEN_TTL=900

# Refresh token TTL in seconds (default: 2592000 = 30 days)
JWT_REFRESH_TOKEN_TTL=2592000


# =============================================================================
# Application URLs (used in email links, CORS, CSP headers)
# =============================================================================

# The public URL of the frontend — must match the domain above
FRONTEND_URL=https://notesaner.example.com            # (REQUIRED)

# The public API base URL — typically same host, different path prefix
NEXT_PUBLIC_API_URL=https://notesaner.example.com/api # (REQUIRED)

# WebSocket URL — must use wss:// in production (TLS)
NEXT_PUBLIC_WS_URL=wss://notesaner.example.com/ws     # (REQUIRED)


# =============================================================================
# Feature Flags
# =============================================================================

# Allow new user registrations. Set to false after initial admin account setup.
ALLOW_REGISTRATION=false

# Require email verification before first login
REQUIRE_EMAIL_VERIFICATION=true


# =============================================================================
# Logging & Observability
# =============================================================================

# NestJS log level: error | warn | log | verbose | debug
LOG_LEVEL=info

# OpenTelemetry endpoint (optional — set to enable distributed tracing)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Sentry DSN (optional — set to enable error reporting)
# SENTRY_DSN=


# =============================================================================
# Optional: SAML SSO (Keycloak, Authentik, Azure AD)
# Leave blank to disable SAML authentication
# =============================================================================

# Your application's Entity ID (must match IdP configuration)
# SAML_ENTITY_ID=https://notesaner.example.com

# IdP Single Sign-On URL
# SAML_SSO_URL=https://keycloak.example.com/auth/realms/corp/protocol/saml

# Path to the IdP public certificate inside the server container
# Mount the cert into the container and reference its path here
# SAML_CERTIFICATE_PATH=/run/secrets/saml_idp_cert


# =============================================================================
# Optional: OIDC SSO (Authentik, Google Workspace, Okta)
# Leave blank to disable OIDC authentication
# =============================================================================

# OIDC_ISSUER=https://authentik.example.com/application/o/notesaner/
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=


# =============================================================================
# Optional: GitHub Plugin Registry
# Needed for the plugin marketplace feature
# A fine-grained PAT with read:packages scope is sufficient
# =============================================================================

# GITHUB_TOKEN=ghp_xxxxxx

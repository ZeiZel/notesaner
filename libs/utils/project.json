{
  "name": "utils",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/utils/src",
  "projectType": "library",
  "tags": ["scope:lib", "type:lib"],
  "targets": {
    "type-check": {
      "command": "tsc --noEmit -p libs/utils/tsconfig.json"
    },
    "test": {
      "command": "vitest run --config libs/utils/vitest.config.ts"
    },
    "test:watch": {
      "command": "vitest --config libs/utils/vitest.config.ts"
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["eslint {projectRoot}/src --ext .ts,.tsx"]
      }
    }
  }
}

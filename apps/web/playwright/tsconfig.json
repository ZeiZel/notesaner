{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strict": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "../src/__tests__/accessibility/**/*.ts",
    "../src/__tests__/e2e/**/*.ts",
    "../src/__tests__/benchmarks/**/*.ts",
    "./**/*.ts",
    "./e2e/**/*.ts",
    "./fixtures/**/*.ts",
    "./utils/**/*.ts"
  ],
  "exclude": ["node_modules"]
}

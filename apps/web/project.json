{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/web"
      },
      "configurations": {
        "development": {
          "outputPath": "dist/apps/web"
        },
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "web:build",
        "dev": true,
        "port": 3000
      },
      "configurations": {
        "development": {
          "buildTarget": "web:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "web:build:production",
          "dev": false
        }
      }
    },
    "export": {
      "executor": "@nx/next:export",
      "options": {
        "buildTarget": "web:build:production"
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/apps/web"],
      "options": {
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/web/**/*.{ts,tsx}"]
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config=apps/web/playwright/e2e.config.ts",
        "cwd": "."
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "apps/web"
      }
    },
    "benchmark": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx tools/benchmarks/run-benchmarks.ts",
        "cwd": "."
      },
      "configurations": {
        "unit": {
          "command": "npx tsx tools/benchmarks/run-benchmarks.ts --suite editor"
        },
        "browser": {
          "command": "npx tsx tools/benchmarks/run-benchmarks.ts --suite browser"
        },
        "lighthouse": {
          "command": "npx tsx tools/benchmarks/run-benchmarks.ts --suite lighthouse"
        },
        "save-baseline": {
          "command": "npx tsx tools/benchmarks/run-benchmarks.ts --save-baseline"
        }
      }
    },
    "benchmark:browser": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec playwright test --config=apps/web/playwright/benchmark.config.ts",
        "cwd": "."
      }
    },
    "benchmark:lighthouse": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx @lhci/cli autorun --config=.lighthouserc.js",
        "cwd": "."
      }
    }
  },
  "tags": ["scope:web", "type:app"]
}

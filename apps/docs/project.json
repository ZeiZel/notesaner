{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/docs/src",
  "tags": ["type:app", "scope:app"],
  "targets": {
    "serve": {
      "executor": "nx:run-script",
      "options": {
        "script": "start",
        "cwd": "apps/docs"
      }
    },
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build",
        "cwd": "apps/docs"
      },
      "outputs": ["{workspaceRoot}/dist/apps/docs"]
    },
    "clear": {
      "executor": "nx:run-script",
      "options": {
        "script": "clear",
        "cwd": "apps/docs"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "apps/docs"
      }
    }
  }
}

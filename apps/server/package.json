{
  "name": "@notesaner/server",
  "version": "0.0.1",
  "private": true,
  "description": "Notesaner NestJS backend server",
  "license": "AGPL-3.0",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "prisma-generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma-migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma-push": "prisma db push --schema=./prisma/schema.prisma",
    "prisma-studio": "prisma studio --schema=./prisma/schema.prisma",
    "prisma-seed": "prisma db seed",
    "migrate:safe": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/migrate-safe.ts",
    "migrate:safe:dry-run": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/migrate-safe.ts --dry-run",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "migrate:status": "prisma migrate status --schema=./prisma/schema.prisma",
    "migrate:diff": "prisma migrate diff --from-migrations ./prisma/migrations --to-schema-datamodel ./prisma/schema.prisma --exit-code",
    "migrate:diff:sql": "prisma migrate diff --from-migrations ./prisma/migrations --to-schema-datamodel ./prisma/schema.prisma --script",
    "migrate:check": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/check-migrations.ts",
    "migrate:sh": "bash scripts/migrate.sh",
    "migrate:sh:dry-run": "bash scripts/migrate.sh --dry-run",
    "rollback": "bash scripts/rollback.sh",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation-express": "^0.62.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/instrumentation-ioredis": "^0.62.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.60.0",
    "@opentelemetry/instrumentation-pg": "^0.66.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "^6.0.0",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "bullmq": "^5.0.0",
    "chokidar": "^4.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "ioredis": "^5.0.0",
    "nestjs-pino": "^4.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-http": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.0.0",
    "prom-client": "^15.1.3",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.0",
    "zod": "^3.23.0"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/ws": "^8.5.13",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}

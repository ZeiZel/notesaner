{
  "name": "@notesaner/server",
  "version": "0.0.0",
  "private": true,
  "description": "Notesaner NestJS backend server",
  "license": "AGPL-3.0",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "prisma-generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma-migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma-push": "prisma db push --schema=./prisma/schema.prisma",
    "prisma-studio": "prisma studio --schema=./prisma/schema.prisma",
    "prisma-seed": "prisma db seed",
    "migrate:safe": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/migrate-safe.ts",
    "migrate:safe:dry-run": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/migrate-safe.ts --dry-run",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "migrate:status": "prisma migrate status --schema=./prisma/schema.prisma",
    "migrate:diff": "prisma migrate diff --from-migrations ./prisma/migrations --to-schema-datamodel ./prisma/schema.prisma --exit-code",
    "migrate:diff:sql": "prisma migrate diff --from-migrations ./prisma/migrations --to-schema-datamodel ./prisma/schema.prisma --script",
    "migrate:check": "ts-node --compiler-options {\"module\":\"CommonJS\"} scripts/check-migrations.ts",
    "migrate:sh": "bash scripts/migrate.sh",
    "migrate:sh:dry-run": "bash scripts/migrate.sh --dry-run",
    "rollback": "bash scripts/rollback.sh",
    "type-check": "tsc --noEmit"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}

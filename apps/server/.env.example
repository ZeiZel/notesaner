# ==========================================
# Server Configuration
# ==========================================
PORT=4000
NODE_ENV=development

# ==========================================
# Database
# ==========================================
DATABASE_URL="postgresql://notesaner:notesaner@localhost:5432/notesaner?schema=public"

# ==========================================
# ValKey / Redis
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=2592000

# ==========================================
# CORS
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000

# ==========================================
# File Storage
# ==========================================
STORAGE_ROOT=/var/lib/notesaner/workspaces

# ==========================================
# Registration
# ==========================================
ALLOW_REGISTRATION=true

# ==========================================
# BullMQ
# ==========================================
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info

# ==========================================
# TOTP / 2FA
# ==========================================
TOTP_APP_NAME=Notesaner

# ==========================================
# GitHub Plugin Registry
# ==========================================
GITHUB_TOKEN=

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "outDir": "dist/scripts",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "prisma/seed.ts",
    "prisma/fixtures/**/*.ts",
    "prisma/migrations/migration-utils.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
